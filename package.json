{
  "name": "horus-ict",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all --parallel=8",
    "build:libs": "nx run-many --target=build --projects=tag:type:lib --parallel=8",
    "build:apps": "nx run-many --target=build --projects=tag:type:app --parallel=8",
    "dev": "nx run-many --target=dev --all --parallel=20 --output-style=stream",
    "predev": "npm i"
  },
  "license": "ISC",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pg": "^8.21.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@nx/js": "^20.8.4",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "nx": "20.8.4",
    "typescript": "6.0.3"
  }
}
