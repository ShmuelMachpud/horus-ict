{
  "name": "horus-ict",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*/*",
    "libs/*"
  ],
 "scripts": {
  "build": "nx run-many --target=build --projects=tag:type=app",
  "build:libs": "nx run-many --target=build --projects=tag:type=lib",
  "predev": "npm i",
  "dev": "nx run-many --target=dev --all --parallel=10 --output-style=stream"
},
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "http-status-codes": "^2.3.0",
    "nodemon": "^3.1.14",
    "nx": "20.8.4",
    "typescript": "6.0.3"
  }
}
