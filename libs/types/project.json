{
  "name": "types",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/types/src",
  "projectType": "library",
  "tags": ["type:lib"],
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "libs/types"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -w",
        "cwd": "libs/types"
      }
    }
  }
}