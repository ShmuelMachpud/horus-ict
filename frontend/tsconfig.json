{
  "compilerOptions": {
    "noImplicitAny": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "typeRoots": ["src/types, node_modules/@types"],
    "baseUrl": "./src/",
    "noUnusedLocals": true,
    "noImplicitThis": true,
    "removeComments": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "allowUnreachableCode": false,
    "paths": {
      "@icons": ["icons/index"],
      "@Types": ["Types/index"],
      "@globalTypes": ["Utils/types"],
      "@socket": ["Utils/socket"],
      "@localStorage": ["Utils/localStorage"],
      "@constants": ["Utils/constants"],
      "@helpers": ["Utils/helpers"],
      "@utils/*": ["Utils/*"],
      "@hooks/*": ["Hooks/*"],
      "@pages/*": ["Pages/*"],
      "@api": ["api/index"],
      "@atoms": ["Atoms/index"],
      "@components/*": ["Components/*"],
      "@/*": ["*"],
    }
  },
  "include": [
    "src",
    "src/global/icons/components/.tsx",
    "playwright",
    "src/cac/threat-alerts/services/threatAlerts.api.service.ts",
  ]
}
