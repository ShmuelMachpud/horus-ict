{
"$schema": "./node_modules/nx/schemas/nx-schema.json",
  "npmScope": "horus",
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build", "test", "lint"]
      }
    }
  },
  "targetDefaults": {
     "dev": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"]
    }
  }
}