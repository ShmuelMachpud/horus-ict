{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "files-server",
  "projectType": "application",
  "sourceRoot": "apps/global/files-server/src",
  "tags": ["type:app"],
  "implicitDependencies": [ "helpers", "middlewares","utils", "types"],
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "apps/global/files-server"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon --config ../../../nodemon.json",
        "cwd": "apps/global/files-server"
      }
    }
  }
}