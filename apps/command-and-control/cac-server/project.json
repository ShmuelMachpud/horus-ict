{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "cac-server",
  "projectType": "application",
  "sourceRoot": "apps/command-and-control/cac-server/src",
  "implicitDependencies": ["utils", "helpers", "middlewares"],
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc",
        "cwd": "apps/command-and-control/cac-server"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon --config ../../../nodemon.json",
        "cwd": "apps/command-and-control/cac-server"
      }
    }
  }
}