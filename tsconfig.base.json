{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "strict": true,
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "lib": ["dom", "esnext"],
    "types": ["node"],
    "paths": {
      "@horus/shared-types": ["./libs/shared-types/dist/index"]
    }
  }
}